{
  "name": "scribbles",
  "version": "0.1.5",
  "description": "Electron + Vue note-taking app that records audio, transcribes with Whisper, and formats with Gemma via Ollama — all locally.",
  "author": "Thomas Cober",
  "repository": {
    "type": "git",
    "url": "https://github.com/tcober/Scribbles.git"
  },
  "main": "electron/main.js",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n vite,electron -c blue,green \"vite\" \"wait-on tcp:5173 && cross-env NODE_ENV=development electron .\"",
    "build": "vite build",
    "start": "electron .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "vendor:whisper": "bash scripts/vendor-whisper.sh",
    "pack": "npm run vendor:whisper && vite build && electron-builder --dir",
    "dist": "npm run vendor:whisper && vite build && electron-builder",
    "release": "npm run vendor:whisper && vite build && electron-builder --publish always"
  },
  "build": {
    "appId": "com.scribbles.app",
    "productName": "Scribbles",
    "artifactName": "Scribbles-${version}-${arch}.${ext}",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "afterPack": "build/afterPack.cjs",
    "files": [
      "dist/**",
      "electron/**",
      "build/icon.png"
    ],
    "extraResources": [
      {
        "from": "resources/whisper",
        "to": "whisper"
      }
    ],
    "mac": {
      "icon": "build/icon.icns",
      "category": "public.app-category.productivity",
      "identity": null,
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "arm64"
          ]
        }
      ]
    },
    "publish": [
      {
        "provider": "github"
      }
    ]
  },
  "dependencies": {
    "marked": "^14.1.3",
    "ollama": "^0.5.11"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@pinia/testing": "^1.0.3",
    "@vitejs/plugin-vue": "^5.1.4",
    "@vitest/coverage-v8": "^4.1.8",
    "@vue/test-utils": "^2.4.11",
    "concurrently": "^9.0.1",
    "cross-env": "^7.0.3",
    "electron": "^33.0.2",
    "electron-builder": "^26.8.1",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-vue": "^10.9.2",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "pinia": "^3.0.4",
    "prettier": "^3.8.3",
    "vite": "^5.4.10",
    "vitest": "^4.1.8",
    "vue": "^3.5.12",
    "wait-on": "^8.0.1"
  }
}
